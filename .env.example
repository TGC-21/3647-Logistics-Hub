# Copy this file to .env and fill in your credentials
# Get Supabase keys from: https://supabase.com → Your Project → Settings → API
# Get Onshape API keys from: https://dev.onshape.com/keys (create an API key pair — not an OAuth app)

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Vercel environment variables (for the serverless function)
# Set these in Vercel Dashboard → Settings → Environment Variables
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

ONSHAPE_ACCESS_KEY=your-onshape-access-key
ONSHAPE_SECRET_KEY=your-onshape-secret-key
